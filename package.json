{
    "name": "polyast",
    "version": "1.0.0",
    "description": "Library for traversal of any AST, nodes of which have `type` property",
    "module": "./dist/index.js",
    "main": "./dist/index.js",
    "type": "module",
    "license": "MIT",
    "devDependencies": {
        "@biomejs/biome": "^2.4.9",
        "@rollup/plugin-typescript": "^12.3.0",
        "@types/bun": "latest",
        "rollup": "^4.60.0",
        "rollup-plugin-dts": "^6.4.1",
        "tslib": "^2.8.1"
    },
    "private": false,
    "readme": "./README.md",
    "repository": {
        "type": "git",
        "url": "https://github.com/a-marigold/polyast"
    },
    "bugs": {
        "url": "https://github.com/a-marigold/polyast/issues"
    },
    "sideEffects": false,
    "files": [
        "./dist"
    ],
    "keywords": [
        "traverse",
        "walk",
        "walker",
        "AST",
        "estree"
    ],
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "peerDependencies": {
        "typescript": "^5"
    },
    "author": {
        "name": "marigold",
        "url": "https://github.com/a-marigold"
    },
    "scripts": {
        "lint": "biome check",
        "build": "rollup -c",
        "test": "bun test --concurrent --randomize --rerun-each 16",
        "prepublishOnly": "bun run build"
    },
    "publishConfig": {
        "access": "public"
    }
}
