{
    "$schema": "https://biomejs.dev/schemas/2.4.9/schema.json",

    "vcs": {
        "enabled": true,
        "clientKind": "git"
    },

    "files": {
        "ignoreUnknown": false,
        "includes": ["**", "!dist", "!node_modules"]
    },
    "formatter": {
        "enabled": false
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true
        }
    },

    "assist": {
        "enabled": false
    }
}
